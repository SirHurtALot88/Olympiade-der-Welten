NODE_ENV=production
PORT=3000
OLY_APP_SQLITE_PATH=/app/data/persistence/oly-app.sqlite

# --- Phase-1-Login (optional, standardmaessig AUS) ---------------------------
# Schalter fuer den Login: "1" aktiviert Login-Pflicht + Identitaets-Verdrahtung.
# Bleibt die Variable leer/unset, verhaelt sich die App exakt wie ohne Login.
OLY_AUTH_ENABLED=

# Geheimer Schluessel zum Signieren der Session-Cookies. Zufaelligen, langen
# String erzeugen (z. B. `openssl rand -hex 32`) und geheim halten. In
# Produktion PFLICHT, sobald OLY_AUTH_ENABLED=1 gesetzt ist.
OLY_AUTH_SECRET=bitte-mit-openssl-rand-hex-32-ersetzen

# Passwoerter fuer die zwei festen Benutzer Chris und Franky. In Produktion
# PFLICHT, sobald OLY_AUTH_ENABLED=1 gesetzt ist - sonst schlaegt der Login fehl
# (kein unsicherer Default in Produktion).
OLY_USER_CHRIS_PASSWORD=bitte-echtes-passwort-setzen
OLY_USER_FRANKY_PASSWORD=bitte-echtes-passwort-setzen
