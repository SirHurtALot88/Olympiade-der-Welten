OLY_DOMAIN=deine-domain.de

# --- Phase-1-Login (optional, standardmaessig AUS) ---------------------------
# Schalter fuer den Login: "1" aktiviert Login-Pflicht + Identitaets-Verdrahtung
# (Chris sieht seine Teams, Franky seine). Leer/unset lassen, um den Login
# ausgeschaltet zu lassen - die App laeuft dann wie bisher ohne Anmeldung.
OLY_AUTH_ENABLED=

# Geheimer Schluessel zum Signieren der Session-Cookies. Zufaelligen, langen
# String erzeugen (z. B. `openssl rand -hex 32`) und geheim halten. Sobald
# OLY_AUTH_ENABLED=1 gesetzt ist, ist dieser Wert auf dem Server PFLICHT.
OLY_AUTH_SECRET=bitte-mit-openssl-rand-hex-32-ersetzen

# Passwoerter fuer die zwei festen Benutzer Chris und Franky. Sobald
# OLY_AUTH_ENABLED=1 gesetzt ist, sind diese Werte auf dem Server PFLICHT -
# ohne sie schlaegt der Login fehl (kein unsicherer Default in Produktion).
OLY_USER_CHRIS_PASSWORD=bitte-echtes-passwort-setzen
OLY_USER_FRANKY_PASSWORD=bitte-echtes-passwort-setzen

