# LEC Cockpit — Beispiel-Konfiguration. Kopieren nach `.env` (lokal) bzw. als
# echte Umgebungsvariablen im Deploy setzen. Env-Prefix: LEC_.

NODE_ENV=development
PORT=3000

# Pfad zur SQLite-Datei zur Laufzeit (liest src/lib/db/client.ts direkt aus
# process.env, keine Prisma-DATABASE_URL nötig). In Produktion auf ein
# dauerhaftes Volume zeigen, z. B. /app/data/lec.sqlite.
LEC_SQLITE_PATH=./data/lec.sqlite

# Nur für die Prisma-CLI (generate/migrate) lokal nötig — muss synchron zu
# LEC_SQLITE_PATH gepflegt werden, wenn der Pfad geändert wird.
DATABASE_URL=file:./data/lec.sqlite

# Produktive Domain (Caddy-Reverse-Proxy, siehe KONZEPT §4.2 und deploy/hetzner/).
# Nur informativ/für evtl. Base-URL-Verwendung — kein DNS-/TLS-Setup hier.
LEC_DOMAIN=leccards.duckdns.org

# --- Zugangsschutz (Single-User "Chris", kein OAuth/Nutzerverwaltung) -------
# In Produktion (NODE_ENV=production) ist der Login IMMER an. Lokal in Dev
# per Default AUS, testweise aktivierbar mit LEC_AUTH_ENABLED=1. Ist der Login
# an, aber Passwort/Secret fehlen, sperrt sich die App komplett (fail closed,
# kein unsicherer Default) -- beide Werte sind dann PFLICHT.
LEC_AUTH_ENABLED=
LEC_PASSWORD=bitte-echtes-passwort-setzen
LEC_AUTH_SECRET=bitte-mit-openssl-rand-hex-32-ersetzen
